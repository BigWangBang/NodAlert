{
  "framework": "hugo",
  "buildCommand": "hugo",
  "outputDirectory": "public",
  "installCommand": "npm install -g hugo",
  "devCommand": "hugo server",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
